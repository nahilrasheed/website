---
import type { CollectionEntry, CollectionKey } from 'astro:content'

import { cn } from '../../utils'
import { Icon } from '../user'

type Props = {
  id?: string
  collections?: CollectionEntry<CollectionKey>[]
  class?: string
  next?: { data: { title?: string }; id?: string; slug?: string; link?: string }
  prev?: { data: { title?: string }; id?: string; slug?: string; link?: string }
}

// Get the requested entry
const { id, collections, class: className } = Astro.props
const path = Astro.url.pathname.split('/').slice(0, 2).join('/')

// Get the next and prev entries (modulo to wrap index)
let prev = Astro.props.prev
let next = Astro.props.next

if (!prev && !next && collections && id) {
  const index = collections.findIndex((x) => x.id === id)
  prev = collections[index - 1]
  next = collections[index + 1]
}
---

<div class={cn('flex max-sm:flex-col sm:justify-between gap-2', className)}>
  <span class='min-w-0'>
    {
      prev && (
        <a
          href={prev.link || (prev.slug ? `${path}/${prev.slug}` : `${path}/${prev.id}`)}
          class='group inline-flex items-center gap-x-2 rounded-xl px-4 py-2 no-underline transition-colors duration-300 hover:bg-muted max-sm:max-w-[80%] sm:flex'
        >
          <Icon name='arrow-right-animated' class='size-5 shrink-0 rotate-180 stroke-muted-foreground transition-colors group-hover:stroke-primary' />
          <p class='truncate font-medium transition-colors'>{prev.data.title}</p>
        </a>
      )
    }
  </span>

  <span class='min-w-0'>
    {
      next && (
        <a
          href={next.link || (next.slug ? `${path}/${next.slug}` : `${path}/${next.id}`)}
          class='group inline-flex items-center gap-x-2 rounded-xl px-4 py-2 text-right no-underline transition-colors duration-300 hover:bg-muted max-sm:float-end max-sm:max-w-[80%] sm:flex'
        >
          <p class='truncate font-medium transition-colors'>{next.data.title}</p>
          <Icon name='arrow-right-animated' class='size-5 shrink-0 stroke-muted-foreground transition-colors group-hover:stroke-primary' />
        </a>
      )
    }
  </span>
</div>
