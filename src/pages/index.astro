---
import { Image } from 'astro:assets'

import PostPreview from '@/components/pages/PostPreview.astro'
import { getBlogCollection } from '@/utils/blog'
import { getEnrichedVaultCollection } from '@/utils/vault'
import { Button, Icon, Label, Section } from '@/components/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import { ProjectCard, ImageCard } from '@/components/about'
import config from '@/site-config'

const MAX_ITEMS = 5

// Get posts and notes
const allPosts = await getBlogCollection()
const allNotes = await getEnrichedVaultCollection()

// Create unified content list with type and date
type ContentItem = 
  | { type: 'post'; data: typeof allPosts[number]; date: Date }
  | { type: 'note'; data: typeof allNotes[number]; date: Date }

const contentItems: ContentItem[] = [
  ...allPosts.map(post => ({
    type: 'post' as const,
    data: post,
    date: post.data.updatedDate ?? post.data.publishDate
  })),
  ...allNotes
    .filter(note => note.data.publishDate || note.data.updatedDate)
    .map(note => ({
      type: 'note' as const,
      data: note,
      date: (note.data.updatedDate ?? note.data.publishDate)!
    }))
]

// Sort by date descending and take latest
const latestContent = contentItems
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, MAX_ITEMS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='India'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label title='Github' as='a' href='https://github.com/nahilrasheed' target='_blank'>
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
          <Label title='Linkedin' as='a' href='https://linkedin.com/in/nahilrasheed' target='_blank'>
            <Icon name='linkedin' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>
          Hi, I'm Nahil Rasheed.
          <span class='font-mono tracking-tight'> aka <span class='text-primary'>0xnhl</span></span>
        </p>
        <p>
          Cybersecurity enthusiast, developer, and lifelong learner. I break things to understand how they work, and build them back securely. Welcome to my digital vault of security research, code experiments, and tech adventures!
        </p>
        <div class='flex flex-wrap items-center gap-3'>
          <a href='/vault' class='group flex flex-col items-start gap-x-3 gap-y-2 rounded-2xl border bg-background px-4 py-2 text-sm shadow-sm transition-shadow hover:shadow-md'>
            <div class='flex flex-row items-center gap-x-3'>
              <p class='font-medium text-muted-foreground'>🗃️ Explore the Vault</p>
              <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' class='stroke-muted-foreground group-hover:stroke-primary ml-auto'>
                <line x1='5' y1='12' x2='19' y2='12' class='translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100' />
                <polyline points='12 5 19 12 12 19' class='translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1' />
              </svg>
            </div>
            <span class='text-xs text-muted-foreground'>A collection of my notes and writeups</span>
          </a>
          <Button title='More about me' class='ml-auto w-fit' href='/about' variant='ahead' />
        </div>
      </Section>
      
      {
        latestContent.length > 0 && (
          <Section title='Recent'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {latestContent.map((item) => (
                item.type === 'post' ? (
                  <PostPreview post={item.data} />
                ) : (
                  <PostPreview note={{ title: item.data.data.title || item.data.slug, slug: item.data.slug, date: item.date, draft: item.data.data.publish === false }} />
                )
              ))}
            </ul>
          </Section>
        )
      }

      <Section title='Projects'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='https://revx-7r6.pages.dev/'
            heading='RevX'
            subheading='Collaborative Project Sharing Platform'
            imagePath='/src/assets/projects/revx.png'
          />
          <ProjectCard
            href='/projects'
            heading='More projects'
            subheading='Check out more projects'
            imagePath='/src/assets/projects/image.png'
          />
        </div>
      </Section>

      <Section title='Certifications'>
        <div class='flex flex-col gap-3'>
          <ImageCard
            as='a'
            heading='Google Cybersecurity Professional Certificate'
            subheading='Google'
            date='Dec 2025'
            href='https://www.coursera.org/account/accomplishments/specialization/48W6CHQVROD8'
            imagePath='/src/assets/about/gcpc.png'
          />
          <ImageCard
            as='a'
            heading='Cisco Ethical Hacker'
            subheading='Cisco'
            date='July 2025'
            href='https://www.credly.com/badges/f806a313-6c62-4810-b196-eecc93dcb6a8/'
            imagePath='/src/assets/about/cisco-eh.png'
          />
        </div>
      </Section>
    </div>
  </main>
</PageLayout>
