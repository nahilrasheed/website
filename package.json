{
  "name": "nahil-website",
  "type": "module",
  "version": "1.1.0",
  "scripts": {
    "dev": "astro dev",
    "dev:check": "astro check --watch & astro dev",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "deploy": "wrangler pages deploy dist",
    "sync": "astro sync",
    "check": "astro check",
    "astro": "astro",
    "format": "prettier --write  '**/*.{js,jsx,ts,tsx,md,mdx,astro}'",
    "lint": "eslint --fix 'src/**/*.{js,ts,jsx,tsx,astro}'",
    "check-all": "bun lint && bun sync && bun check && bun format",
    "clean": "rm -rf .astro .vercel dist"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/mdx": "7.0.2",
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@flowershow/remark-wiki-link": "^3.4.0",
    "@pagefind/default-ui": "^1.5.2",
    "@unocss/astro": "^66.7.4",
    "astro": "7.0.6",
    "force-graph": "^1.51.4",
    "hast-util-select": "^6.0.4",
    "katex": "^0.16.47",
    "mdast-util-to-string": "^4.0.0",
    "node-html-parser": "^7.1.0",
    "reading-time": "^1.5.0",
    "rehype-callouts": "^2.2.0",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0",
    "unocss": "^66.7.4"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/force-graph": "^1.26.3",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^1.7.0",
    "glob": "^13.0.6",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.107.0"
  }
}