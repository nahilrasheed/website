---
import PageLayout from '@/layouts/BaseLayout.astro'
import { getVaultTree, getUniqueVaultTagsWithCount } from '@/utils/vault'
import VaultTree from '@/components/vault/VaultTree.astro'
import { Button, Icon } from '@/components/user'

const meta = {
  title: 'Vault',
  description: 'Knowledge Base'
}

const tree = await getVaultTree()
const allTags = await getUniqueVaultTagsWithCount()
const topTags = allTags.slice(0, 4)
const canLink = (node: (typeof tree)[number]) => !!node.slug && node.showLink !== false
---

<PageLayout meta={meta}>
  <div class='mt-4 max-w-[90rem] mx-auto px-4 lg:px-0'>
    <h1 id='content-header' class='animate text-3xl font-bold mb-4 tracking-tight text-foreground'>Vault</h1>
    
    <div class='animate vault-animate-intro flex flex-col sm:flex-row flex-wrap items-start sm:items-center sm:justify-between gap-4 mb-8'>
      <div class='flex items-center justify-between w-full sm:w-auto gap-4'>
        <p class='text-muted-foreground text-lg'>Welcome to my digital garden. Explore the notes below.</p>
        <div class='flex sm:hidden items-center gap-0.5 bg-muted rounded-lg p-0.5'>
          <button
            type='button'
            id='grid-view-btn-mobile'
            class='view-toggle-btn p-1.5 rounded-md transition-colors active'
            aria-label='Grid view'
            title='Grid view'
          >
            <Icon name='grid' class='size-4.5' />
          </button>
          <button
            type='button'
            id='list-view-btn-mobile'
            class='view-toggle-btn p-1.5 rounded-md transition-colors'
            aria-label='List view'
            title='List view'
          >
            <Icon name='list-lucide' class='size-4.5' />
          </button>
        </div>
      </div>
      
      {!!topTags.length && (
        <div class='flex items-center gap-3 text-base sm:text-sm flex-wrap sm:ml-auto'>
          <div class='hidden sm:flex items-center gap-0.5 bg-muted rounded-lg p-0.5'>
            <button
              type='button'
              id='grid-view-btn'
              class='view-toggle-btn p-1.5 rounded-md transition-colors active'
              aria-label='Grid view'
              title='Grid view'
            >
              <Icon name='grid' class='size-4.5' />
            </button>
            <button
              type='button'
              id='list-view-btn'
              class='view-toggle-btn p-1.5 rounded-md transition-colors'
              aria-label='List view'
              title='List view'
            >
              <Icon name='list-lucide' class='size-4.5' />
            </button>
          </div>
          <Icon name='tag-2' class='size-5 text-muted-foreground' />
          {topTags.map(([tag]) => (
            <Button title={tag} href={`/tags/${tag}`} variant='pill' class='text-sm sm:text-xs' />
          ))}
          <a aria-label='View all vault tags' href='/tags' data-astro-prefetch class='text-base sm:text-xs whitespace-nowrap'>
            View all →
          </a>
        </div>
      )}
    </div>

    <div id='grid-view' class='animate vault-animate-grid vault-grid grid gap-4 sm:grid-cols-2 lg:grid-cols-3 items-start'>
      {tree.map((node) => (
        node.children.length > 0 ? (
          <details class='vault-folder group relative border rounded-xl bg-card/60 text-card-foreground shadow-sm transition-all duration-200 hover:bg-card/80 hover:z-30 open:z-50 open:bg-card open:shadow-2xl open:rounded-b-none'>
            <summary class='flex items-center gap-2 p-4 cursor-pointer list-none transition-colors select-none'>
              <Icon
                name='chevron-right'
                 class='size-4.5 shrink-0 transition-transform duration-200 ease-out group-open:rotate-90 text-muted-foreground'
              />
                {canLink(node) ? (
                  <a href={`/vault/${node.slug}`} class='font-semibold text-lg decoration-dotted underline underline-offset-4 hover:decoration-solid hover:text-primary break-words'>
                       {node.title}
                       {node.entry?.data.publish === false && <span class='text-red-500 text-sm ml-1'>(Unpublished)</span>}
                   </a>
               ) : (
                   <span class='font-semibold text-lg flex-1 break-words'>{node.title}</span>
               )}
            </summary>
            <div class='vault-content absolute top-[calc(100%-1px)] left-[-1px] right-[-1px] border-x border-b border-border bg-card rounded-b-xl shadow-xl overflow-hidden'>
                <div class='vault-inner px-4 pb-4 pt-2'>
                  <ul class='pt-2 space-y-0.5'>
                      {node.children.map((child) => (
                         <VaultTree node={child} collapsed />
                      ))}
                  </ul>
                </div>
            </div>
          </details>
        ) : (
           canLink(node) ? (
             <a href={`/vault/${node.slug}`} class='block p-4 relative border rounded-xl bg-card/60 text-card-foreground shadow-sm transition-all duration-300 hover:bg-card/80 hover:z-30'>
                <span class='font-semibold text-lg pl-6 block break-words'>
                    {node.title}
                    {node.entry?.data.publish === false && <span class='text-red-500 text-sm ml-1'>(Unpublished)</span>}
                </span>
             </a>
           ) : (
             <div class='block p-4 relative border rounded-xl bg-card/60 text-card-foreground shadow-sm'>
                <span class='font-semibold text-lg pl-6 block break-words'>
                    {node.title}
                    {node.entry?.data.publish === false && <span class='text-red-500 text-sm ml-1'>(Unpublished)</span>}
                </span>
             </div>
           )
        )
      ))}
      <div id='grid-spacer' class='col-span-full' aria-hidden='true'></div>
    </div>

    <!-- List View (Tree) -->
    <div id='list-view' class='animate vault-animate-grid hidden'>
      <VaultTree class='text-base' collapsed />
    </div>
  </div>
</PageLayout>

<style>
  .vault-folder {
    contain: layout style;
  }

  .vault-animate-intro {
    animation-delay: 100ms;
  }

  .vault-animate-grid {
    animation-delay: 150ms;
  }

  .vault-content {
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.2s ease-out, transform 0.2s ease-out;
    max-height: 0;
  }

  .vault-folder[open] .vault-content {
    opacity: 1;
    transform: translateY(0);
    max-height: 1000px;
    transition: opacity 0.2s ease-out, transform 0.2s ease-out, max-height 0.3s ease-out;
  }

  .vault-inner {
    animation: slideIn 0.2s ease-out;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Prevent animation on page load */
  .vault-grid:not(.initialized) .vault-content {
    transition: none;
  }

  /* View toggle button styles */
  .view-toggle-btn {
    color: hsl(var(--muted-foreground));
  }

  .view-toggle-btn:hover {
    color: hsl(var(--foreground));
    background-color: hsl(var(--muted) / 0.5);
  }

  .view-toggle-btn.active {
    color: hsl(var(--primary));
    background-color: hsl(var(--muted) / 0.3);
  }

  /* List view tree enhancements */
  #list-view :global(vault-tree) {
    font-size: 0.95rem;
  }

  #list-view :global(vault-tree ul) {
    margin-left: 0.5rem;
  }

  #list-view :global(vault-tree a) {
    padding: 0.1rem 0.4rem;
    border-radius: 0.375rem;
    transition: background-color 0.15s ease;
  }

  #list-view :global(vault-tree a:hover) {
    background-color: hsl(var(--muted) / 0.5);
  }
</style>

<script>
  const VAULT_VIEW_KEY = 'vault-view-preference'

  // Accordion behavior: close other folders when one opens
  function initializeVaultAccordion() {
    const grid = document.querySelector('.vault-grid')
    const spacer = document.getElementById('grid-spacer')
    if (!grid) return

    const folders = grid.querySelectorAll('.vault-folder')
    
    // Mark as initialized to enable animations
    setTimeout(() => grid.classList.add('initialized'), 100)

    const updateSpacer = () => {
      if (!spacer) return
      
      const openFolder = grid.querySelector('.vault-folder[open]')
      if (openFolder) {
        const content = openFolder.querySelector('.vault-content')
        if (content) {
          const contentHeight = content.getBoundingClientRect().height
          spacer.style.height = `${contentHeight}px`
        }
      } else {
        spacer.style.height = '0px'
      }
    }

    // Listen for any toggle events inside the grid (including subfolders)
    grid.addEventListener('toggle', () => {
      setTimeout(updateSpacer, 50)
    }, true)

    folders.forEach((folder) => {
      const summary = folder.querySelector('summary')
      if (!summary) return

      summary.addEventListener('click', () => {
        const isOpen = folder.hasAttribute('open')
        
        if (!isOpen) {
          // Close all other folders with smooth animation
          folders.forEach((otherFolder) => {
            if (otherFolder !== folder && otherFolder.hasAttribute('open')) {
              otherFolder.removeAttribute('open')
            }
          })
          
          // Update spacer and scroll into view after opening
          setTimeout(() => {
            updateSpacer()
            const content = folder.querySelector('.vault-content')
            if (content) {
              const rect = content.getBoundingClientRect()
              const viewportHeight = window.innerHeight
              if (rect.bottom > viewportHeight) {
                folder.scrollIntoView({ behavior: 'smooth', block: 'start' })
              }
            }
          }, 50)
        } else {
          // Closing - reset spacer
          setTimeout(updateSpacer, 50)
        }
      })
    })

    // Handle folder note links (prevent closing on link click)
    const folderLinks = grid.querySelectorAll('.vault-folder a')
    folderLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.stopPropagation()
      })
    })
  }

  // View toggle functionality
  function initializeViewToggle() {
    const gridViewBtn = document.getElementById('grid-view-btn')
    const listViewBtn = document.getElementById('list-view-btn')
    const gridViewBtnMobile = document.getElementById('grid-view-btn-mobile')
    const listViewBtnMobile = document.getElementById('list-view-btn-mobile')
    const gridView = document.getElementById('grid-view')
    const listView = document.getElementById('list-view')

    if (!gridView || !listView) return

    const setView = (view: 'grid' | 'list') => {
      if (view === 'grid') {
        gridView.classList.remove('hidden')
        listView.classList.add('hidden')
        gridViewBtn?.classList.add('active')
        listViewBtn?.classList.remove('active')
        gridViewBtnMobile?.classList.add('active')
        listViewBtnMobile?.classList.remove('active')
      } else {
        gridView.classList.add('hidden')
        listView.classList.remove('hidden')
        gridViewBtn?.classList.remove('active')
        listViewBtn?.classList.add('active')
        gridViewBtnMobile?.classList.remove('active')
        listViewBtnMobile?.classList.add('active')
      }
      localStorage.setItem(VAULT_VIEW_KEY, view)
    }

    // Restore saved preference
    const savedView = localStorage.getItem(VAULT_VIEW_KEY) as 'grid' | 'list' | null
    if (savedView) {
      setView(savedView)
    }

    gridViewBtn?.addEventListener('click', () => setView('grid'))
    listViewBtn?.addEventListener('click', () => setView('list'))
    gridViewBtnMobile?.addEventListener('click', () => setView('grid'))
    listViewBtnMobile?.addEventListener('click', () => setView('list'))
  }

  function initializeVault() {
    initializeVaultAccordion()
    initializeViewToggle()
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeVault)
  } else {
    initializeVault()
  }

  // Re-initialize on view transitions (Astro navigation)
  document.addEventListener('astro:page-load', initializeVault)
</script>
