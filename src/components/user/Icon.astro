---
import { Icons } from '../../libs/icons'

export interface Props extends astroHTML.JSX.SVGAttributes {
  name: keyof typeof Icons
  label?: string
  color?: string
  size?: number | string
  class?: string
}

const { name, label, size = '1.5em', color, class: className, style, ...props } = Astro.props
const a11yAttrs = label ? ({ 'aria-label': label } as const) : ({ 'aria-hidden': 'true' } as const)

const inlineStyle = color ? `color: ${color};${style ? ` ${style}` : ''}` : style;
---

<svg
  {...a11yAttrs}
  class={className}
  width={size}
  height={size}
  viewBox='0 0 24 24'
  fill='currentColor'
  set:html={Icons[name]}
  style={inlineStyle}
  {...props}
/>
